{
  "name": "kytsunia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test:run",
    "import:legacy": "node --env-file=.env --import tsx scripts/import-legacy.ts",
    "eval:persona": "node --env-file=.env --import tsx scripts/eval-persona.ts",
    "refresh:regulars": "node --env-file=.env --import tsx scripts/refresh-regulars.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "better-sqlite3": "^12.9.0",
    "grammy": "^1.42.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
